# Supabase project credentials for the cloud backup/restore feature
# (Laporan > Sync ke Cloud / Restore dari Cloud). Copy this file to `.env`
# and fill in the real values from your Supabase project dashboard:
# Project Settings > API.
#
# The app works fully offline without these — if they're left empty, cloud
# sync silently no-ops and the app shows "Supabase belum dikonfigurasi".

# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_URL=

# Project anon/public API key (safe to expose in a client app; access is
# still gated by the RLS policy on the app_backups table — see
# supabase/schema.sql for the policy and its security trade-offs)
EXPO_PUBLIC_SUPABASE_ANON_KEY=
